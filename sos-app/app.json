      },
      "predictiveBackGestureEnabled": false,
      "package": "com.arqummalik1.sosMobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "bcc5df5d-719f-46f0-ab1e-be7b1d7d3ea9"
